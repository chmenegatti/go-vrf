# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.
#
# Each NSX-T environment uses a prefix (e.g. TESP2, TESP3, TESP5, TESP6).
# Replicate the three vars below per environment you need.

TESP2_BASEPATH=https://nsx.example.local
TESP2_USERNAME=apiuser
TESP2_PASSWORD=changeme

TESP3_BASEPATH=https://nsx.example.local
TESP3_USERNAME=apiuser
TESP3_PASSWORD=changeme

TESP5_BASEPATH=https://nsx.example.local
TESP5_USERNAME=apiuser
TESP5_PASSWORD=changeme

TESP6_BASEPATH=https://nsx.example.local
TESP6_USERNAME=apiuser
TESP6_PASSWORD=changeme
